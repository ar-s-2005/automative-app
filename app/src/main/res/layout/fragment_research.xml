<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="ANALYTICS &amp; RESEARCH"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-condensed-light"
            android:text="Automotive intelligence, market trends, and AI-comparisons."
            android:textColor="#D4AF37"
            android:textSize="13sp" />

        <!-- 1. COMPARISON HUB (Dynamic side-by-side spec comparison) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="CAR SPEC COMPARISON"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="24dp"
            app:strokeColor="#2C2C35"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvCompareInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="Go to 'Buy Cars' and click 'Compare' on up to 3 cars to see their side-by-side specifications here."
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvComparisonList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearCompare"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:text="Clear Comparison"
                    android:textColor="@color/red"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. GEMINI AI RECOMMENDATIONS (Ask Budget, Style, etc.) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="ELITE AI ADVISOR"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="24dp"
            app:strokeColor="#2C2C35"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Budget input -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColorHint="@color/gray_text"
                    app:boxStrokeColor="#D4AF37"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintTextColor="#D4AF37">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAiBudget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Your Budget (e.g., ₹2 Cr)"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Brand Preference -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColorHint="@color/gray_text"
                    app:boxStrokeColor="#D4AF37"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintTextColor="#D4AF37">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAiBrand"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Brand Preferences (e.g., Porsche)"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Body Style -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColorHint="@color/gray_text"
                    app:boxStrokeColor="#D4AF37"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintTextColor="#D4AF37">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAiStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Body Style / Performance (e.g., SUV, 600+ HP)"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Additional Info -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColorHint="@color/gray_text"
                    app:boxStrokeColor="#D4AF37"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintTextColor="#D4AF37">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAiRequirements"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Other Requirements (e.g., daily driver)"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Generate recommendations btn -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGetAiReport"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="Generate Elite AI Report"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    app:backgroundTint="#D4AF37"
                    app:cornerRadius="12dp" />

                <!-- Output Area -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAiResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_dark_lighter"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#3C3C45"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="GEMINI RECOMMENDS"
                            android:textColor="#D4AF37"
                            android:textSize="12sp"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvAiResponse"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif"
                            android:text="Consulting Advisor..."
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. FIXED ANALYTICS SECTIONS (EV, Luxury, SUV, Fuel, Brand Rankings) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="MARKET PERFORMANCE REPORTS"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

        <!-- EV Market Trends -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="20dp"
            app:strokeColor="#2C2C35"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EV Market Growth ⚡"
                    android:textColor="@color/cyan"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif"
                    android:text="Electric luxury vehicle registrations surged by +48% year-over-year. Segment dominators include Porsche Taycan and Audi e-tron GT. Range, fast-charging index, and battery durability remain key buyer drivers."
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />

                <!-- Mock Growth Chart indicator -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:layout_marginTop="12dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_centerVertical="true"
                        android:background="#1C1C24" />

                    <View
                        android:layout_width="280dp"
                        android:layout_height="8dp"
                        android:layout_centerVertical="true"
                        android:background="@color/cyan" />
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Luxury Segment Growth -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="20dp"
            app:strokeColor="#2C2C35"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Luxury Segment Growth 📈"
                    android:textColor="#D4AF37"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif"
                    android:text="Demand for high-end track-capable and custom-crafted models like Mercedes-Benz Maybach and BMW M division increased by +18%. Wealth resilience drives consistent sales across metro cities."
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:layout_marginTop="12dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_centerVertical="true"
                        android:background="#1C1C24" />

                    <View
                        android:layout_width="200dp"
                        android:layout_height="8dp"
                        android:layout_centerVertical="true"
                        android:background="#D4AF37" />
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SUV Market Trends -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="20dp"
            app:strokeColor="#2C2C35"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUV Market Trends 🚙"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif"
                    android:text="Ultra-luxury SUVs (BMW X7, Mercedes G-Wagon) hold more than 62% of the premium transaction market. Commanding road presence paired with high off-road capability is highly valued."
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fuel Price & Resale Analysis -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="20dp"
            app:strokeColor="#2C2C35"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resale Value Trends 💰"
                    android:textColor="@color/purple"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif"
                    android:text="Porsche 911 retains the highest value retention index, retaining up to 88% of original value after 3 years. This is followed closely by Mercedes-Benz G-Wagon and specialized BMW M performance divisions."
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Brand Demand Rankings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="20dp"
            app:strokeColor="#2C2C35"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brand Demand Ranking 🏁"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Demand listings -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="1. Porsche (Demand Index: 98.4) • Strong collector values"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="2. BMW (Demand Index: 92.1) • High daily driver versatility"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="3. Mercedes-Benz (Demand Index: 89.9) • Elite luxury status"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="4. Audi (Demand Index: 85.2) • Outstanding digital tech"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
