<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_black">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Header -->
        <FrameLayout
            android:id="@+id/btn_back_dealer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_search_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:rotation="180"
                android:src="@drawable/ic_research_nav"
                app:tint="@color/white"
                android:contentDescription="Back Navigation" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="SHOWROOM LOCATOR"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btn_back_dealer"
            app:layout_constraintStart_toEndOf="@id/btn_back_dealer"
            app:layout_constraintTop_toTopOf="@id/btn_back_dealer" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Verified Elite Partner Showrooms"
            android:textColor="@color/gold"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back_dealer" />

        <!-- Showroom 1: BMW -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dealer_card1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_luxury"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle">

            <TextView
                android:id="@+id/tv_dealer_name1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elite BMW Central"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_dealer_addr1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Plot 22, Connaught Place, New Delhi, Delhi 110001"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/tv_dealer_name1" />

            <TextView
                android:id="@+id/tv_dealer_contact1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📞 +91 11 4983 2345"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tv_dealer_addr1"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒 9:00 AM - 8:00 PM"
                android:textColor="@color/cyan"
                android:textSize="11sp"
                app:layout_constraintBottom_toBottomOf="@id/tv_dealer_contact1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_dealer_contact1" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Showroom 2: Porsche -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dealer_card2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_luxury"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/dealer_card1">

            <TextView
                android:id="@+id/tv_dealer_name2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Porsche Centre Mumbai"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_dealer_addr2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Vasundhara Building, Ground Floor, Bhulabhai Desai Road, Mumbai 400026"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/tv_dealer_name2" />

            <TextView
                android:id="@+id/tv_dealer_contact2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📞 +91 22 2353 9110"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tv_dealer_addr2"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒 10:00 AM - 7:00 PM"
                android:textColor="@color/cyan"
                android:textSize="11sp"
                app:layout_constraintBottom_toBottomOf="@id/tv_dealer_contact2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_dealer_contact2" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Showroom 3: Mercedes -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dealer_card3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_luxury"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/dealer_card2">

            <TextView
                android:id="@+id/tv_dealer_name3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mercedes-Benz Signature Bengaluru"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_dealer_addr3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="105, Kasturba Road, Nunegundlapalli, Bangalore 560001"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/tv_dealer_name3" />

            <TextView
                android:id="@+id/tv_dealer_contact3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📞 +91 80 6734 5000"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tv_dealer_addr3"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒 9:00 AM - 8:30 PM"
                android:textColor="@color/cyan"
                android:textSize="11sp"
                app:layout_constraintBottom_toBottomOf="@id/tv_dealer_contact3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_dealer_contact3" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
