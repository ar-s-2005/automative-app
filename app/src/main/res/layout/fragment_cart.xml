<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.tools.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_black">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Header -->
        <FrameLayout
            android:id="@+id/btn_back_cart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_search_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:rotation="180"
                android:src="@drawable/ic_research_nav"
                app:tint="@color/white"
                android:contentDescription="Back Navigation" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="ELITE WORKSPACE"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btn_back_cart"
            app:layout_constraintStart_toEndOf="@id/btn_back_cart"
            app:layout_constraintTop_toTopOf="@id/btn_back_cart" />

        <!-- Section 1: Reserved Vehicles in Shopping Cart -->
        <TextView
            android:id="@+id/tv_cart_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="RESERVED VEHICLES IN CART"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back_cart" />

        <!-- Cart Linear Container for programmatic item inflation -->
        <LinearLayout
            android:id="@+id/cart_items_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_cart_header" />

        <!-- Cart Placeholder -->
        <TextView
            android:id="@+id/tv_cart_placeholder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_luxury"
            android:gravity="center"
            android:padding="20dp"
            android:text="Your shopping cart is currently vacant."
            android:textColor="@color/gray_text"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_cart_header" />

        <!-- Place Order / Reserve All CTA -->
        <FrameLayout
            android:id="@+id/btn_checkout_container"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_gradient_purple"
            app:layout_constraintTop_toBottomOf="@id/cart_items_container">

            <Button
                android:id="@+id/btn_checkout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                app:backgroundTint="@android:color/transparent"
                android:text="CONFIRM VEHICLE RESERVATIONS"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Section 2: Scheduled Showroom Test Drives -->
        <TextView
            android:id="@+id/tv_bookings_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="SCHEDULED SHOWROOM TEST DRIVES"
            android:textColor="@color/cyan"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_checkout_container" />

        <LinearLayout
            android:id="@+id/bookings_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_bookings_header" />

        <!-- Bookings Placeholder -->
        <TextView
            android:id="@+id/tv_bookings_placeholder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_luxury"
            android:gravity="center"
            android:padding="20dp"
            android:text="No upcoming test drives requested."
            android:textColor="@color/gray_text"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_bookings_header" />

        <!-- Section 3: Your Listed Luxury Vehicles (For Sale) -->
        <TextView
            android:id="@+id/tv_listings_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="YOUR ACTIVE FOR-SALE LISTINGS"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bookings_container" />

        <LinearLayout
            android:id="@+id/user_listings_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_listings_header" />

        <!-- Listings Placeholder -->
        <TextView
            android:id="@+id/tv_listings_placeholder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_luxury"
            android:gravity="center"
            android:padding="20dp"
            android:text="You haven't listed any cars for sale yet."
            android:textColor="@color/gray_text"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_listings_header" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            android:indeterminateTint="@color/gold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
