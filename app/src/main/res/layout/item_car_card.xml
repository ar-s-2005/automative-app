<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:strokeColor="#2C2C35"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_dark"
        android:orientation="vertical">

        <!-- Image Container with Brand Badge and Wishlist Button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <ImageView
                android:id="@+id/carImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />

            <!-- Brand Badge -->
            <TextView
                android:id="@+id/brandBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_margin="12dp"
                android:background="#D4AF37"
                android:fontFamily="sans-serif-black"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="PORSCHE"
                android:textColor="@color/black"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Wishlist Button -->
            <ImageButton
                android:id="@+id/wishlistBtn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_margin="12dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_heart_empty"
                android:contentDescription="Toggle Wishlist" />

        </RelativeLayout>

        <!-- Information Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/carName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Porsche 911 Turbo S"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <!-- Specifications summary -->
            <TextView
                android:id="@+id/carSpecs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-light"
                android:text="2024 • Petrol • 640 HP"
                android:textColor="@color/gray_text"
                android:textSize="13sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <!-- Mileage -->
                <TextView
                    android:id="@+id/carMileage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="monospace"
                    android:text="1,200 km"
                    android:textColor="@color/cyan"
                    android:textSize="14sp" />

                <!-- Price tag -->
                <TextView
                    android:id="@+id/carPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-black"
                    android:text="₹3.3Cr"
                    android:textColor="#D4AF37"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <!-- Buttons bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- Add to Compare -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/compareBtn"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="Compare"
                    android:textColor="@color/white"
                    app:strokeColor="#2C2C35" />

                <!-- Buy Now Button (Purple gradient/color style) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buyNowBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1.2"
                    android:text="Buy Now"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/purple" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
