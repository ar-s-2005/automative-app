<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black">

    <!-- Top Action Bar -->
    <RelativeLayout
        android:id="@+id/buyHeaderBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif-black"
            android:text="ELITE INVENTORY"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Wishlist toggle filter -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWishlistToggleFilter"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="Filter Wishlist Only"
            app:icon="@drawable/ic_heart_empty"
            app:iconTint="#FF3333" />
    </RelativeLayout>

    <!-- Sub-Filter Horizontal Brand Category bar -->
    <LinearLayout
        android:id="@+id/brandsFilterLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/buyHeaderBar">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupBrands"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:checked="true"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/card_dark"
                    app:chipStrokeColor="#2C2C35" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBMW"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BMW"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/card_dark"
                    app:chipStrokeColor="#2C2C35" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAudi"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audi"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/card_dark"
                    app:chipStrokeColor="#2C2C35" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBenz"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mercedes-Benz"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/card_dark"
                    app:chipStrokeColor="#2C2C35" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPorsche"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Porsche"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/card_dark"
                    app:chipStrokeColor="#2C2C35" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Main List of Cars -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBuyCars"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/brandsFilterLayout" />

    <!-- No results View -->
    <TextView
        android:id="@+id/tvNoCarsFound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="No Luxury Machines Found."
        android:textColor="@color/gray_text"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loading Bar -->
    <ProgressBar
        android:id="@+id/buyLoading"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:indeterminateTint="#D4AF37"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Floating Compare Sheet/Card (Appears when cars are selected) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCompareFloating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/purple"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeColor="@color/white"
        app:strokeWidth="1dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvCompareFloatingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:fontFamily="sans-serif-medium"
                android:text="2 Cars Selected for Comparison"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompareFloatingAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Compare"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#D4AF37"
                app:cornerRadius="10dp" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
